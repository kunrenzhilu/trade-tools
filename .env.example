# ── 复制此文件为 .env，填入真实值 ──────────────────────────
# .env 已加入 .gitignore，不会提交到 Git

# Alpaca（Phase 2 执行层用）
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_PAPER=true

# IBKR（Phase 3 生产用）
IBKR_HOST=127.0.0.1
IBKR_PORT=7497

# 告警（Phase 3 用）
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
