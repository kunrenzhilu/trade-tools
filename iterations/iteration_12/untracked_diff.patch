+ 687→            output_file=tmp_path / "weights_fallback.json",
+ 688→        )
+ 689→
+ 690→        # 若产生权重，验证：fallback 触发（dd_constrained=True）或无权重（极端无交易场景）
+ 691→        has_weights = any(weights for weights in report.groups.values() if weights)
+ 692→        if has_weights:
