+1043→            return spy_close.pct_change().dropna()
+1044→        except Exception as e:
+1045→            logger.warning(
+1046→                f"[MatrixBacktest] SPY benchmark fetch failed: {e} — "
+1047→                f"alpha will degrade to 0.0"
+1048→            )
+1049→            return None
