+            failed = 0
+            errors = 0
+
+    return {
+        "passed": passed,
+        "failed": failed,
+        "errors": errors,
+        "warnings": warnings,
+        "summary": summary,
+        "collected": collected,  # 仅 collect-only 模式有意义
+    }
+
