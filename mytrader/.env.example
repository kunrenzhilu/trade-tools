# ── 复制此文件为 .env，填入真实值 ──────────────────────────
# .env 已加入 .gitignore，不会提交到 Git

# ── Alpaca 美股执行层 ────────────────────────────────────────
ALPACA__API_KEY=your_alpaca_api_key_here
ALPACA__SECRET_KEY=your_alpaca_secret_key_here
ALPACA__PAPER=true                   # true=沙盒账户; false=真实账户

# ── IBKR 港美股执行层（Phase 3 生产用）────────────────────────
IBKR__HOST=127.0.0.1
IBKR__PORT=7497
IBKR__CLIENT_ID=1
IBKR__READONLY=true

# ── 通知推送 ─────────────────────────────────────────────────
# Telegram Bot（https://core.telegram.org/bots/tutorial）
NOTIFICATION__TELEGRAM_ENABLED=false
NOTIFICATION__TELEGRAM_BOT_TOKEN=your_bot_token_here
NOTIFICATION__TELEGRAM_CHAT_ID=your_chat_id_here

# 企业微信 Webhook（群机器人）
NOTIFICATION__WECHAT_WORK_ENABLED=false
NOTIFICATION__WECHAT_WORK_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key

# ── 执行模式覆盖 ─────────────────────────────────────────────
# EXECUTION__MODE=semi_auto          # paper | semi_auto | auto
# SYSTEM__ENV=live                   # paper | live

# ── Phase 4：数据源 & 扫描标的 ──────────────────────────────
# 使用 Alpaca 数据源（SIP，15min 延迟，免费全量）
# DATA__PROVIDER=alpaca

# 扫描标的（JSON 数组格式覆盖 default.yaml 列表）
# WATCHLIST__SYMBOLS='["AAPL","MSFT","TSLA","NVDA","SPY","QQQ"]'
# WATCHLIST__LOOKBACK_DAYS=90

